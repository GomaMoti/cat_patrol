{
  "manifest_version": 3,
  "name": "グロックと猫のパトロール (Grok & Cat Patrol)",
  "version": "2.1.0",
  "description": "タイムラインの怪しい垢をワンポチでGrok分析。Analyze X accounts instantly with Grok.",
  "permissions": [
    "storage",
    "clipboardWrite",
    "tabs"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://x.com/*",
        "https://twitter.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "style.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_title": "グロックと猫のパトロール"
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}